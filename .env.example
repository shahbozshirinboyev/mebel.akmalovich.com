SECRET_KEY=replace-with-a-long-random-secret
DEBUG=False
ALLOWED_HOSTS=mebel.akmalovich.com,www.mebel.akmalovich.com
CSRF_TRUSTED_ORIGINS=https://mebel.akmalovich.com,https://www.mebel.akmalovich.com

# Use either DATABASE_URL or DB_* variables.
# DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/mebel_akmalovich_db
DB_ENGINE=django.db.backends.postgresql
DB_NAME=mebel_akmalovich_db
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=127.0.0.1
DB_PORT=5432
DB_CONN_MAX_AGE=60

SECURE_SSL_REDIRECT=True
SESSION_COOKIE_SECURE=True
CSRF_COOKIE_SECURE=True
SECURE_HSTS_SECONDS=31536000
SECURE_HSTS_INCLUDE_SUBDOMAINS=True
SECURE_HSTS_PRELOAD=True
